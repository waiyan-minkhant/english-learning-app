generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  teacher
  student
}

enum LiveSessionStatus {
  scheduled
  live
  ended
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  name                 String
  passwordHash         String
  role                 UserRole              @default(student)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  teacherClasses       Class[]               @relation("TeacherClasses")
  classMemberships     ClassStudent[]
  conversationAttempts ConversationAttempt[]
}

model Class {
  id        String         @id @default(uuid())
  teacherId String
  lessonId  String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  teacher   User           @relation("TeacherClasses", fields: [teacherId], references: [id])
  students  ClassStudent[]
  sessions  LiveSession[]

  @@map("Class")
}

model ClassStudent {
  id        String   @id @default(uuid())
  classId   String
  studentId String
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("ClassStudent")
}

model LiveSession {
  id        String            @id @default(uuid())
  roomId    String            @unique
  status    LiveSessionStatus @default(scheduled)
  startedAt DateTime?
  endedAt   DateTime?
  classId   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  class     Class             @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("LiveSession")
}

model ConversationAttempt {
  id                   String   @id @default(uuid())
  userId               String
  lessonId             String
  exerciseId           String
  sessionId            String?
  transcript           String
  answeredQuestion     Int
  grammar              Int
  vocabulary           Int
  sentenceCompleteness Int
  feedback             String
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseId])
  @@map("ConversationAttempt")
}
