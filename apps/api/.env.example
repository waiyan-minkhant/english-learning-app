PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/english_learning?schema=public"
POSTGRES_PASSWORD=postgres
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:3000
# Production (Vercel): set to https://your-frontend.vercel.app for CORS + Socket.IO

# pgAdmin (docker-compose login + web UI)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_URL=http://localhost:5050

# Redis (API on host → published port 6379)
REDIS_URL=redis://localhost:6379
# Redis hostname when connecting from another compose service
REDIS_URL_INTERNAL=redis://redis:6379

# RedisInsight web UI (docker-compose port 5540)
REDISINSIGHT_URL=http://localhost:5540

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
REALTIME_DISCONNECT_TIMEOUT_MS=5000
TEACHER_AUTO_END_SESSION_MS=5000
REDIS_REALTIME_TTL_SECONDS=7200
